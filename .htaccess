# ============ URLs limpias (sin extensión .html) ============
RewriteEngine On

# Redirigir /pagina.html -> /pagina (301, evita contenido duplicado)
RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Servir internamente /pagina desde /pagina.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ============ Redirecciones de URLs .php antiguas ============
Redirect 301 /metrologia.php https://indelsrl.com.ar/metrologia
Redirect 301 /mesasSoldadura.php https://indelsrl.com.ar/mesas-soldadura
Redirect 301 /tratamientoSuperficies.php https://indelsrl.com.ar/pintura-aspiracion
